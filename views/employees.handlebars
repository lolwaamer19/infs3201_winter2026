<h1>Employee Details</h1>

<p>Name: {{employee.name}}</p>
<p>Phone: {{employee.phone}}</p>

<p><a href="/edit/{{employee._id}}">Edit Details</a></p>


<h2>Shifts</h2>

<table border="1" cellpadding="6">
  <thead>
    <tr>
      <th>Date</th>
      <th>Start Time</th>
      <th>End Time</th>
    </tr>
  </thead>
  <tbody>
    {{#each shifts}}
      <tr>
        <td>{{this.date}}</td>
        <td class="{{this.startClass}}">{{this.startTime}}</td>
        <td>{{this.endTime}}</td>
      </tr>
    {{/each}}
  </tbody>
</table>

<style>
  .beforeNoon { background-color: yellow; }
</style>