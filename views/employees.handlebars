<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Employee Details</title>
  <style>
    .beforeNoon { background: yellow; }
    table, td, th { border: 1px solid #ddd; border-collapse: collapse; padding: 6px; }
  </style>
</head>
<body>

<h1>Employee Details</h1>

<p>Name: {{employee.name}}</p>
<p>Phone: {{employee.phone}}</p>

<p><a href="/edit/{{employee.employeeId}}">Edit Details</a></p>

<h2>Shifts</h2>

<table>
  <thead>
    <tr>
      <th>Date</th>
      <th>Start Time</th>
      <th>End Time</th>
    </tr>
  </thead>
  <tbody>
    {{#each shifts}}
      <tr>
        <td>{{date}}</td>
        <td class="{{startClass}}">{{startTime}}</td>
        <td>{{endTime}}</td>
      </tr>
    {{/each}}
  </tbody>
</table>

</body>
</html>