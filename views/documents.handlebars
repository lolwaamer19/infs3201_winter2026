<h1>Documents for {{employee.name}}</h1>

{{#if message}}
  <p style="color:green;">{{message}}</p>
{{/if}}

<form method="POST" action="/employee/{{employee._id}}/documents" enctype="multipart/form-data">
  <p>
    <input type="file" name="document" accept=".pdf">
  </p>
  <button type="submit">Upload Document</button>
</form>

<h2>Uploaded Documents</h2>

{{#if documents.length}}
  <ul>
    {{#each documents}}
      <li><a href="/uploads/{{this.filename}}">{{this.originalName}}</a></li>
    {{/each}}
  </ul>
{{else}}
  <p>No documents uploaded yet.</p>
{{/if}}

<p><a href="/employee/{{employee._id}}">Back to Employee</a></p>